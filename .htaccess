# ════════════════════════════════════════════════════════════════
# DeepThink AI — Apache Server Configuration
# Upload this file alongside index.html to public_html/
# ════════════════════════════════════════════════════════════════

# ─── HTTPS REDIRECT ─────────────────────────────────────────────
# Force all traffic to HTTPS
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ─── WWW → NON-WWW (canonical URL = deepthinkai.org) ────────────
# Comment out these 3 lines if you prefer www.deepthinkai.org
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
</IfModule>

# ─── GZIP COMPRESSION ────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ─── BROWSER CACHING ─────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML — short cache (site updates frequently)
    ExpiresByType text/html                "access plus 1 hour"

    # CSS & JS — 1 month (add ?v=X to bust when you update)
    ExpiresByType text/css                 "access plus 1 month"
    ExpiresByType application/javascript   "access plus 1 month"

    # Fonts — 1 year (never change)
    ExpiresByType font/woff2               "access plus 1 year"
    ExpiresByType font/woff                "access plus 1 year"

    # Images — 6 months
    ExpiresByType image/svg+xml            "access plus 6 months"
    ExpiresByType image/webp               "access plus 6 months"
    ExpiresByType image/png                "access plus 6 months"
    ExpiresByType image/jpeg               "access plus 6 months"
    ExpiresByType image/x-icon             "access plus 1 year"
</IfModule>

# ─── SECURITY HEADERS ────────────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # XSS Protection (legacy browsers)
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Basic content security policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ─── ERROR PAGES ─────────────────────────────────────────────────
# Redirect all 404s back to home (single-page site)
ErrorDocument 404 /index.html

# ─── BLOCK .GIT EXPOSURE ─────────────────────────────────────────
RedirectMatch 404 /\.git(/|$)
RedirectMatch 404 /\.github(/|$)

# ─── REMOVE SERVER SIGNATURE ────────────────────────────────────
ServerSignature Off
